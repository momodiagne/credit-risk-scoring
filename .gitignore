# Données lourdes (exclut les CSV bruts et nettoyés, régénérables via le pipeline)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Modèles entraînés : committés volontairement (petits fichiers) pour que le
# repo soit utilisable directement après un clone, sans ré-entraînement.
# Régénérer avec :
#   python -m src.data.preprocess
#   python -m src.features.build_features
#   python -m src.models.train
!models/*.joblib
!models/.gitkeep

# Python & Caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Environnements virtuels
.venv/
venv/
env/

# Jupyter Notebooks (fichiers temporaires)
.ipynb_checkpoints/

# Fichiers d'environnement & OS
.env
.DS_Store
Thumbs.db

# IDEs (VSCode, PyCharm)
.vscode/
.idea/